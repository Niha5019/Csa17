        "colors = [\"Red\", \"Green\", \"Blue\"]\n",
        "\n",
        "for stateA in colors:\n",
        "    for stateB in colors:\n",
        "\n",
        "        # Constraint: Adjacent states cannot have same color\n",
        "        if stateA != stateB:\n",
        "            print(\"State A =\", stateA,\n",
        "                  \"State B =\", stateB)"
      ]
